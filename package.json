{
  "name": "intellisense-recursion",
  "displayName": "IntelliSense Recursion",
  "description": "Cmd+Click on type names in hover tooltips to navigate to definitions — like IntelliJ IDEA",
  "version": "0.1.4",
  "publisher": "newdlops",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/intellisense-recursion"
  },
  "keywords": [
    "hover",
    "go to definition",
    "type navigation",
    "intellisense",
    "cmd+click",
    "intellij"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:java",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:csharp",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:ruby",
    "onLanguage:php",
    "onLanguage:swift",
    "onLanguage:kotlin"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "intellisenseRecursion.goToType",
        "title": "Go to Definition (from hover)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "tsc -p ./ && node esbuild.js",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package",
    "deploy:local": "npm run package && code --install-extension intellisense-recursion-0.1.3.vsix --force && echo 'Installed! Restart VS Code to activate.'"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
